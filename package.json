{
  "name": "@luceon/eduasset-cms",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "upload:server": "node --env-file=.env server/upload-server.mjs",
    "db:server": "node --env-file=.env server/db-server.mjs",
    "proxy:server": "node server/proxy-server.mjs",
    "uat:start": "bash start-uat.sh",
    "uat:build": "bash start-uat.sh --build",
    "uat:stop": "bash start-uat.sh stop",
    "uat:smoke": "bash uat/smoke-test.sh",
    "local:check": "node scripts/local-env-check.mjs",
    "test:static": "node --check server/upload-server.mjs && bash -n uat/smoke-test.sh && tsc --noEmit && vite build",
    "uat:docker:config": "docker compose -f docker-compose.yml -f docker-compose.local.yml -f docker-compose.override.yml config --quiet",
    "test": "bash scripts/run-tests.sh",
    "test:smoke": "bash uat/smoke-test.sh",
    "test:server": "node server/tests/worker-smoke.mjs",
    "test:e2e": "pnpm --dir uat exec playwright test",
    "test:local-mineru": "node server/test-local-mineru.mjs",
    "tier2:standard:check": "node scripts/tier2-standard-check.mjs"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "0.487.0",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.13.2",
    "sonner": "2.0.3",
    "tw-animate-css": "1.3.8",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.8.3",
    "vite": "6.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
