{
  "id": "math_workbook",
  "description": "Chinese or English mathematics workbook.",
  "auto_detect_rules": [
    {"pattern": "^第\\s*\\d+\\s*章", "weight": 8},
    {"pattern": "^(要点归纳|疑难分析|基础训练|拓展训练|本章复习题|阶段训练\\d*)$", "weight": 7},
    {"pattern": "^(例\\s*\\d+|选择题|填空题|证明|作图)", "scope": "all", "weight": 3},
    {"pattern": "^\\d+\\.\\d+\\s+.*\\b(numbers|factors|algebra|angles|triangles|fractions|equations|graphs|probability|statistics|geometry)\\b", "weight": 2}
  ],
  "heading_patterns": {"chapter": "^第\\s*\\d+\\s*章", "lesson": "^\\d+\\.\\d+", "stage_test": "^阶段训练\\d*", "chapter_review": "^本章复习题$"},
  "section_role_rules": [
    {"pattern": "^第\\s*\\d+\\s*章", "role": "chapter", "section_type": "chapter"},
    {"pattern": "^\\d+\\.\\d+", "role": "lesson", "section_type": "lesson"},
    {"pattern": "^要点归纳$", "role": "key_points", "section_type": "teaching_column"},
    {"pattern": "^疑难分析$", "role": "worked_examples", "section_type": "teaching_column"},
    {"pattern": "^(基础训练|拓展训练|习题\\s*\\d+)", "role": "problem_group", "section_type": "problem_group"},
    {"pattern": "^[一二三四五六七八九十]+、", "role": "problem_group", "section_type": "problem_group"},
    {"pattern": "^(阶段训练\\d*|本章复习题)$", "role": "assessment", "section_type": "assessment"}
  ],
  "asset_role_rules": [
    {"section_role": "key_points", "asset_type": "concept", "role": "key_points"},
    {"section_role": "worked_examples", "asset_type": "example", "role": "worked_example"},
    {"section_role": "problem_group", "asset_type": "exercise", "role": "problem_group"},
    {"section_role": "assessment", "asset_type": "assessment", "role": "assessment"}
  ],
  "segmentation": {"item_start_pattern": "^\\d+[.．、]\\s*", "choice_pattern": "^[A-D][.．、]\\s+", "subitem_pattern": "^（[0-9]+）|^\\([0-9]+\\)"},
  "example_start_pattern": "^例\\s*\\d+",
  "task_type_rules": [
    {"pattern": "选择题|（ ）|\\( \\)", "task_type": "multiple_choice"},
    {"pattern": "填空题|____|_______|_", "task_type": "fill_blank"},
    {"pattern": "证明", "task_type": "proof"},
    {"pattern": "作图", "task_type": "construction"},
    {"pattern": "如图|图像|图象", "task_type": "figure_based_problem"}
  ],
  "answer_policy": "answer_section_excluded"
}
