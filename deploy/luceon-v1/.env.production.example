COMPOSE_PROJECT_NAME=luceonweb2026-production
LUCEON_WEB_PORT=15000
LUCEON_API_PORT=15001
LUCEON_NETWORK=luceonweb2026-production-net
LUCEON_TEX_CONTAINER=luceonweb2026-production-texlive

# Production authentication must be enabled. Recovery permission is an explicit allowlist.
LUCEON_AUTH_DISABLED=false
LUCEON_PIPELINE_ADMIN_EMAILS=ops@example.com
LUCEON_PUBLIC_WORKSPACE_USER_ID=2
LUCEON_PUBLIC_WORKSPACE_EMAIL=workspace@luceon.local

# Existing durable services. GPU wrapper may stay offline during this release.
MINIO_ENDPOINT=https://minio.example.internal
MINIO_ACCESS_KEY=replace-me
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET=mineru-files
MINIO_MDS_BUCKET=mds
WORKFLOW_DATABASE_URL=mysql+pymysql://user:password@mysql.example.internal:3306/luceon_workflow
GPU_WRAPPER_URL=http://gpu-wrapper.example.internal:8083
GPU_WRAPPER_API_KEY=replace-me

LUCEON_WORKER_V1_BATCH_ENABLED=false
LUCEON_WORKER_V1_AUTO_RETRY_ENABLED=false
LUCEON_PUBLIC_API_BASE_URL=https://luceon.example.com/api

DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
DASHSCOPE_API_KEY=replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen3.7-plus
